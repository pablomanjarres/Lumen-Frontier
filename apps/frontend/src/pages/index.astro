---
/**
 * Landing Page - Choose Your Experience
 * "Old Money in space": deep forest/burgundy night, brass starlight,
 * an elegant serif brand title, warm hairline experience cards.
 * Selection between LumenOS (Dashboard) and Lumenverse (Space Navigation).
 */
import LandingLayout from '@/layouts/LandingLayout.astro'
---

<LandingLayout
  title="Lumen Frontier - Choose Your Experience"
  description="Push the Edge of What You Know. Choose between LumenOS Dashboard or Lumenverse 3D Explorer."
>
  <div class="landing-wrapper">
      <!-- Starfield Background (warm brass / ivory starlight) -->
      <div class="starfield" aria-hidden="true">
        <div class="stars"></div>
        <div class="stars2"></div>
        <div class="stars3"></div>
      </div>

      <!-- Atmospheric warm glow overlay -->
      <div class="gradient-overlay" aria-hidden="true"></div>

      <!-- Main Content -->
      <main class="main-content">
        <!-- Brand Header -->
        <header class="brand-header">
          <div class="logo-badge">
            <svg class="logo-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h1 class="brand-title" aria-label="Lumen Frontier">
            <span class="word-mask"><span class="word" style="--i:0" aria-hidden="true">Lumen</span></span>
            <span class="word-mask"><span class="word" style="--i:1" aria-hidden="true">Frontier</span></span>
          </h1>
          <p class="brand-tagline">Push the Edge of What You Know</p>
          <div class="tagline-underline"></div>
        </header>

        <!-- Experience Cards -->
        <div class="experience-grid">
          <!-- LumenOS Card -->
          <a href="/dashboard" class="experience-card lumenos">
            <div class="card-content">
              <div class="card-header">
                <div class="card-icon-wrapper">
                  <svg class="card-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM14 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zM14 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z" />
                  </svg>
                </div>
                <div class="card-title-group">
                  <h2 class="card-title">LumenOS</h2>
                  <p class="card-subtitle">Dashboard Experience</p>
                </div>
              </div>

              <p class="card-description">
                Your personalized learning command center. Organize notes, track progress, and visualize your knowledge journey with powerful widgets.
              </p>

              <div class="card-features">
                <span class="feature-pill">📊 Analytics</span>
                <span class="feature-pill">📝 Smart Notes</span>
                <span class="feature-pill">📈 Progress Tracking</span>
              </div>

              <div class="card-footer">
                <span class="enter-text">Enter LumenOS</span>
                <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>

          <!-- Lumenverse Card -->
          <a href="/lumenverse" class="experience-card lumenverse">
            <div class="card-content">
              <div class="card-header">
                <div class="card-icon-wrapper">
                  <svg class="card-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div class="card-title-group">
                  <h2 class="card-title">Lumenverse</h2>
                  <p class="card-subtitle">3D Space Explorer</p>
                </div>
              </div>

              <p class="card-description">
                Navigate through knowledge as an astronaut in space. Explore topics as planets, discover connections, and experience learning in 3D.
              </p>

              <div class="card-features">
                <span class="feature-pill">🌌 Immersive 3D</span>
                <span class="feature-pill">🪐 Planet Topics</span>
                <span class="feature-pill">🚀 Free Navigation</span>
              </div>

              <div class="card-footer">
                <span class="enter-text">Launch Lumenverse</span>
                <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        </div>

        <!-- Bottom Info -->
        <footer class="page-footer">
          <p class="footer-text">Choose your path to mastery</p>
        </footer>
      </main>
    </div>
</LandingLayout>

<style>
  /* ─────────────────────────────────────────────────────────────
     Design tokens (mirrors tailwind.config.mjs / DESIGN-SYSTEM.md).
     Warm ramps only — no generic blue/green/purple/slate.
     ───────────────────────────────────────────────────────────── */
  .landing-wrapper {
    --bg: #1a1413;            /* surface-base  */
    --raised: #221a16;        /* surface-raised */
    --overlay: #2b211c;       /* surface-overlay */

    --brass: #e99218;         /* brass-500 (the one accent) */
    --brass-200: #f7de8f;
    --brass-300: #f3c654;
    --brass-400: #f0af2b;
    --brass-700: #a94f13;

    --burgundy: #d65e68;      /* burgundy-500 */
    --burgundy-300: #f0b3b6;
    --burgundy-400: #e5888d;

    --cognac: #b67049;        /* cognac-500 */
    --cognac-300: #d3ac8d;

    --ivory-100: #faf7f3;     /* text-primary   */
    --ivory-400: #e0cab3;     /* text-secondary */
    --ivory-600: #c39774;     /* text-tertiary  */

    --hairline: rgba(233, 146, 24, 0.14);
    --hairline-strong: rgba(233, 146, 24, 0.35);

    /* one soft warm shadow (matches boxShadow.soft / soft-lg) */
    --shadow-soft: 0 2px 6px -1px rgba(18, 10, 6, 0.45), 0 10px 24px -6px rgba(18, 10, 6, 0.35);
    --shadow-soft-lg: 0 8px 20px -6px rgba(18, 10, 6, 0.55), 0 24px 56px -12px rgba(18, 10, 6, 0.45);

    --radius-card: 0.5rem;    /* 8px  */
    --radius-control: 0.375rem; /* 6px */

    position: relative;
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  /* ── Starfield: warm brass / ivory starlight ── */
  .starfield {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .stars, .stars2, .stars3 {
    position: absolute;
    inset: 0;
    background: transparent;
  }

  .stars {
    background-image:
      radial-gradient(2px 2px at 20px 30px, #faf7f3, transparent),
      radial-gradient(2px 2px at 60px 70px, #f5ede3, transparent),
      radial-gradient(1px 1px at 50px 50px, #faf7f3, transparent),
      radial-gradient(1px 1px at 130px 80px, #f5ede3, transparent),
      radial-gradient(2px 2px at 90px 10px, #faf7f3, transparent);
    background-repeat: repeat;
    background-size: 200px 200px;
    animation: twinkle 6s ease-in-out infinite;
    opacity: 0.5;
  }

  .stars2 {
    background-image:
      radial-gradient(1px 1px at 40px 60px, var(--brass-400), transparent),
      radial-gradient(1px 1px at 110px 20px, var(--brass-200), transparent),
      radial-gradient(1px 1px at 160px 120px, var(--brass), transparent);
    background-repeat: repeat;
    background-size: 180px 180px;
    animation: twinkle 7.5s ease-in-out infinite 1s;
    opacity: 0.4;
  }

  .stars3 {
    background-image:
      radial-gradient(1px 1px at 80px 90px, var(--cognac-300), transparent),
      radial-gradient(1px 1px at 140px 50px, var(--brass-700), transparent);
    background-repeat: repeat;
    background-size: 220px 220px;
    animation: twinkle 9s ease-in-out infinite 2s;
    opacity: 0.3;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.55; }
  }

  /* ── Atmospheric glow: deep forest/burgundy night, brass at center ── */
  .gradient-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 38%, rgba(233, 146, 24, 0.10) 0%, transparent 60%),
      radial-gradient(ellipse at 82% 12%, rgba(193, 63, 82, 0.09) 0%, transparent 55%),
      radial-gradient(ellipse at 16% 88%, rgba(63, 102, 62, 0.08) 0%, transparent 55%);
    pointer-events: none;
  }

  /* ── Main Content ── */
  .main-content {
    position: relative;
    z-index: 10;
    max-width: 1400px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  /* ── Brand Header ── */
  .brand-header {
    text-align: center;
  }

  .logo-badge {
    width: 96px;
    height: 96px;
    margin: 0 auto 2rem;
    /* brass plaque — the sanctioned single warm brand chip */
    background: linear-gradient(150deg, #f3c654 0%, #e99218 46%, #cd6f12 100%);
    border-radius: var(--radius-card);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: var(--shadow-soft-lg), inset 0 1px 0 rgba(255, 253, 247, 0.35);
    opacity: 0;
    animation: fadeIn 0.9s ease-out forwards, float 7s ease-in-out 0.9s infinite;
  }

  .logo-svg {
    width: 44px;
    height: 44px;
    color: var(--bg); /* near-black lightning pressed into the brass */
    filter: drop-shadow(0 1px 1px rgba(18, 10, 6, 0.35));
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-6px); }
  }

  /* ── Serif brand title with a restrained per-word conveyor reveal ── */
  .brand-title {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0 0.28em;
    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
    font-size: clamp(3rem, 9vw, 6rem);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: 0.005em;
    margin-bottom: 1rem;
  }

  .word-mask {
    display: inline-flex;
    overflow: hidden;
    padding-bottom: 0.16em;
    margin-bottom: -0.16em;
  }

  .word {
    display: inline-block;
    /* the single sanctioned warm brand gradient */
    background: linear-gradient(135deg, #f7de8f 0%, #f0af2b 48%, #b67049 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    transform: translateY(110%);
    animation: wordRise 0.85s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
    animation-delay: calc(var(--i) * 0.12s + 0.15s);
  }

  @keyframes wordRise {
    to { transform: translateY(0); }
  }

  .brand-tagline {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(1rem, 2.6vw, 1.375rem);
    color: var(--ivory-400);
    font-weight: 500;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: fadeIn 0.9s ease-out 0.55s forwards;
  }

  .tagline-underline {
    width: 72px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--brass), transparent);
    margin: 0 auto;
    opacity: 0;
    animation: fadeIn 0.9s ease-out 0.7s forwards;
  }

  /* ── Experience Grid ── */
  .experience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(400px, 100%), 1fr));
    gap: 2rem;
    width: 100%;
    max-width: 1000px;
  }

  .experience-card {
    /* per-card warm accent */
    --accent: var(--brass);
    --accent-soft: rgba(233, 146, 24, 0.12);
    --accent-border: rgba(233, 146, 24, 0.30);
    --accent-chip-text: var(--brass-300);

    position: relative;
    background: var(--raised); /* flat rich surface — no glass, no tri-gradient */
    border: 1px solid var(--hairline);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    opacity: 0;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
  }

  .experience-card.lumenverse {
    /* deep wine accent to differentiate — still fully in-palette */
    --accent: var(--burgundy-400);
    --accent-soft: rgba(214, 94, 104, 0.12);
    --accent-border: rgba(214, 94, 104, 0.30);
    --accent-chip-text: var(--burgundy-300);
    animation-delay: 0.55s;
  }

  .experience-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-border);
    box-shadow: var(--shadow-soft-lg);
  }

  .experience-card:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(233, 146, 24, 0.35);
  }

  .card-content {
    position: relative;
    z-index: 1;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: 100%;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .card-icon-wrapper {
    flex-shrink: 0;
  }

  .card-icon {
    width: 48px;
    height: 48px;
    padding: 12px;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-control);
    transition: transform 0.2s ease;
  }

  .experience-card:hover .card-icon {
    transform: scale(1.04);
  }

  .card-title-group {
    flex: 1;
  }

  .card-title {
    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
    font-size: 2.25rem;
    font-weight: 600;
    color: var(--ivory-100);
    line-height: 1.1;
    margin-bottom: 0.125rem;
  }

  .card-subtitle {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    color: var(--ivory-600);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .card-description {
    color: var(--ivory-400);
    line-height: 1.7;
    font-size: 0.9375rem;
  }

  .card-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .feature-pill {
    padding: 0.375rem 0.75rem;
    background: var(--accent-soft);
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-control);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent-chip-text);
    transition: border-color 0.2s ease;
  }

  .experience-card:hover .feature-pill {
    border-color: var(--accent-border);
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--hairline);
  }

  .enter-text {
    font-weight: 600;
    color: var(--ivory-100);
    font-size: 1rem;
    letter-spacing: 0.01em;
  }

  .arrow-icon {
    width: 22px;
    height: 22px;
    color: var(--accent);
    transition: transform 0.2s ease;
  }

  .experience-card:hover .arrow-icon {
    transform: translateX(6px);
  }

  /* ── Footer ── */
  .page-footer {
    opacity: 0;
    animation: fadeIn 1s ease-out 0.85s forwards;
  }

  .footer-text {
    color: var(--ivory-600);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
  }

  /* ── Entrance animations (quiet; neutralized under reduced-motion) ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .landing-wrapper {
      padding: 1.5rem;
    }

    .main-content {
      gap: 3rem;
    }

    .logo-badge {
      width: 80px;
      height: 80px;
    }

    .logo-svg {
      width: 38px;
      height: 38px;
    }

    .experience-grid {
      gap: 1.5rem;
    }

    .card-content {
      padding: 1.5rem;
      gap: 1.25rem;
    }

    .card-title {
      font-size: 1.875rem;
    }

    .card-header {
      gap: 1rem;
    }
  }

  /* Respect reduced motion: land everything in its final, visible state. */
  @media (prefers-reduced-motion: reduce) {
    .word { transform: none; }
    .logo-badge,
    .brand-tagline,
    .tagline-underline,
    .experience-card,
    .page-footer { opacity: 1; }
  }
</style>
