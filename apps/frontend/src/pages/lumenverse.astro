---
/**
 * Lumenverse - 3D Space Navigation
 * Explore knowledge through an immersive planetary universe
 */
import FullscreenLayout from '@/layouts/FullscreenLayout.astro'
import PlanetaryScene from '@/lumenverse/planetary-scene/PlanetaryScene'
import '@/styles/global.css'
---

<FullscreenLayout
  title="Lumenverse - Explore Knowledge in 3D Space"
  description="Navigate through knowledge as an astronaut in space. Explore topics as planets in an immersive 3D universe."
>
  <!-- Back to home button -->
    <a
      href="/"
      class="group fixed left-6 top-6 z-50 inline-flex items-center gap-2 rounded-card border border-hairline bg-surface-overlay/85 px-4 py-2 text-sm font-medium text-primary shadow-soft backdrop-blur-md transition-colors hover:border-brass-700/60 hover:bg-surface-overlay focus-visible:shadow-focus focus-visible:outline-none"
      aria-label="Back to home"
    >
      <svg class="h-5 w-5 text-secondary transition-colors group-hover:text-brass-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      <span class="hidden sm:inline">Back to Home</span>
    </a>

    <!-- Planetary Scene Container -->
    <div id="scene-wrapper">
      <PlanetaryScene client:load />
    </div>
</FullscreenLayout>

<style is:global>

  /* Scene Wrapper */
  #scene-wrapper {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  /* Ensure PlanetaryScene section fills container */
  #scene-wrapper > section {
    width: 100%;
    height: 100%;
  }

</style>
